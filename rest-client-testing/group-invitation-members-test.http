###
GET {{baseurl}}/groups
###
GET {{baseurl}}/users

###3a. Add demon1 group invitation
POST {{baseurl}}/groups/{{groupId}}/invitations/{{demonId}}

###3b. Add tenz group invitation
POST {{baseurl}}/groups/{{groupId}}/invitations/{{tenzId}}

###3c. Remove demon1 group invitation
DELETE  {{baseurl}}/groups/{{groupId}}/invitations/{{demonId}}

###3d. Remove tenz group invitation
DELETE {{baseurl}}/groups/{{groupId}}/invitations/{{tenzId}}

###4a. Add demon1 group member
POST {{baseurl}}/groups/{{groupId}}/members/{{demonId}}?role=leader

###3b. Add tenz group member
POST {{baseurl}}/groups/{{groupId}}/members/{{tenzId}}

###3c. Remove demon1 group member
DELETE  {{baseurl}}/groups/{{groupId}}/members/{{demonId}}

###3d. Remove tenz group member
DELETE {{baseurl}}/groups/{{groupId}}/members/{{tenzId}}

###5. Delete users and groups

### Delete demon
DELETE {{baseurl}}/users/{{demonId}}

###Delete tenz
DELETE {{baseurl}}/users/{{tenzId}}

###Delete group
DELETE {{baseurl}}/groups/{{groupId}}